# Local shell environment for optional Cloudflare example deploys.
#
# Copy this file to .env and fill in the Cloudflare values locally.
# Do not commit .env.

# Required when deploying infra/examples/web to Cloudflare.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DEFAULT_ACCOUNT_ID=

# Optional AWS profile overrides. The template defaults are:
# SST_DEV_AWS_PROFILE=irongate-dev
# SST_PROD_AWS_PROFILE=irongate-prod

# Keep Irongate runtime secrets in SST secrets, not in this file:
# - AuthHmacLookupSecret
# - ResendApiKey
# - AuthSigningPrivateKey when local-es256 is used
# - GoogleClientSecret when Google sign-in is enabled
# - ApplePrivateKey when Sign in with Apple is enabled
