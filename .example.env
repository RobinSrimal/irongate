# Local shell environment for optional tooling and example deploys.
#
# Copy this file to .env and fill in local-only values.
# Do not commit .env.

# Cloudflare deploy credentials.
#
# These belong in .env because SST/Pulumi reads them from the local shell when
# creating optional Cloudflare example resources. They are not passed to the
# Irongate AWS Lambda runtime.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DEFAULT_ACCOUNT_ID=

# Optional AWS profile overrides for local deploy commands.
#
# The template defaults are:
# SST_DEV_AWS_PROFILE=irongate-dev
# SST_PROD_AWS_PROFILE=irongate-prod

# Keep Irongate runtime secrets in SST secrets, not .env:
#
# - AuthHmacLookupSecret
# - ResendApiKey
# - AuthSigningPrivateKey when local-es256 is used
# - GoogleClientSecret when Google sign-in is enabled
# - ApplePrivateKey when Sign in with Apple is enabled
# - Any confidential OAuth client secret referenced by auth.clients.toml
#
# Keep reviewed non-secret configuration in checked-in files:
#
# infra/shared/stage-config.ts:
# - email sender and verification/reset URL bases
# - Google OAuth web client ID
# - Apple Services ID, team ID, and key ID
# - signing mode and key ID
# - example enablement and optional Cloudflare domain
#
# auth.clients.toml:
# - OAuth client IDs, redirect URIs, allowed scopes, allowed origins
# - secret reference names, not raw secret values
